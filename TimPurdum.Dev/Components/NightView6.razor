        <Basemap>
            <BasemapStyle Name="@(_isDarkMode
                ? BasemapStyleName.ArcgisNavigationNight
                : BasemapStyleName.ArcgisNavigation)" />
        </Basemap>
    </Map>

    <!-- widgets here -->
</MapView>

